# 백엔드 origin (Vite dev 프록시 target + OAuth 진입 절대 URL 구성에 사용)
# - 로컬 개발: http://localhost:8080  (FixLog-Server ./gradlew bootRun)
# - 운영:      https://fixlog.art
VITE_BACKEND_URL=http://localhost:8080

# axios baseURL. 서버 context-path(/fixlog)와 일치시킨다.
# dev 에서는 Vite 프록시(/fixlog → VITE_BACKEND_URL)를 태워 same-origin 으로 호출되므로 CORS가 없다.
# 운영에서는 전체 URL(예: https://fixlog.art/fixlog)로 바꾼다.
VITE_API_BASE_URL=/fixlog
